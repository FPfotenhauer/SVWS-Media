# SVWS-Media environment example
# Copy to .env and adjust values for your environment.

# App / secret handling
# Optional: set a fixed secret key for stable encryption across restarts.
# If empty, the app uses data/app_secret.key or generates a runtime fallback.
APP_SECRET=

# SVWS sync configuration
SVWS_BASE_URL=https://localhost:8443
SVWS_SCHEMA=
SVWS_ID_LERNPLATTFORM=1
SVWS_ID_SCHULJAHRESABSCHNITT=1
SVWS_VERIFY_TLS=false
SVWS_USERNAME=Admin
SVWS_PASSWORD=
